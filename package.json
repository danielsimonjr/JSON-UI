{
  "name": "json-ui",
  "version": "0.1.0",
  "private": true,
  "description": "Constrained JSON to UI library. Define a component catalog with Zod schemas; the LLM emits catalog-matching JSON; your app renders it safely. Inspired by Vercel Labs' json-render and Google's A2UI.",
  "license": "Apache-2.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\""
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.1",
    "@types/node": "^25.6.0",
    "jsdom": "^27.4.0",
    "prettier": "^3.7.4",
    "tsx": "^4.19.0",
    "typescript": "5.9.2",
    "vitest": "^4.0.17"
  },
  "engines": {
    "node": ">=18"
  }
}
